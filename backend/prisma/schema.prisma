// Prisma schema for NURisk - Database & Data Layer
// Single source of truth for PostgreSQL + PostGIS database

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["extendedWhereUnique"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core entity models: User, Volunteer, Role, Permission

enum Role {
  PWNU
  PCNU
  RELAWAN
  RELAWAN_ADMIN
  SUPER_ADMIN
  BNPB
}

enum Permission {
  // Incident management permissions
  INCIDENT_CREATE
  INCIDENT_READ
  INCIDENT_UPDATE
  INCIDENT_DELETE
  INCIDENT_APPROVE

  // Volunteer management permissions
  VOLUNTEER_CREATE
  VOLUNTEER_READ
  VOLUNTEER_UPDATE
  VOLUNTEER_DELETE
  VOLUNTEER_APPROVE

  // Shelter/Warehouse management permissions
  SHELTER_CREATE
  SHELTER_READ
  SHELTER_UPDATE
  SHELTER_DELETE
  WAREHOUSE_CREATE
  WAREHOUSE_READ
  WAREHOUSE_UPDATE
  WAREHOUSE_DELETE

  // Logistics permissions
  LOGISTICS_CREATE
  LOGISTICS_READ
  LOGISTICS_UPDATE
  LOGISTICS_DELETE

  // System administration permissions
  USER_MANAGE
  ROLE_MANAGE
  PERMISSION_MANAGE
  SYSTEM_SETTINGS

  // Reporting and analytics permissions
  REPORT_CREATE
  REPORT_READ
  REPORT_UPDATE
  REPORT_DELETE
  ANALYTICS_VIEW
  DASHBOARD_VIEW
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Authentication fields
  username       String  @unique
  passwordHash   String
  email          String?
  phoneNumber    String?
  whatsappNumber String?

  // Profile information
  fullName    String?
  avatarUrl   String?
  region      String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Role and permissions
  role        Role         @default(RELAWAN)
  permissions Permission[] @default([])

  // Relations
  incidents          Incident[]           @relation("CreatedIncidents")
  volunteer          Volunteer?
  auditLogs          AuditLog[]           @relation("ActorAuditLogs")
  notifications      Notification[]       @relation("RecipientNotifications")
  chatMessages       ChatMessage[]        @relation("SenderChatMessages")
  UserSession        UserSession[]
  ChatParticipant    ChatParticipant[]
  TeamMessage        TeamMessage[]
  VerificationResult VerificationResult[]
  PiiAudit           PiiAudit[]

  @@index([username])
  @@index([role])
  @@index([region])
  @@index([isActive])
}

model Volunteer {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Link to user
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Profile information
  fullName  String?
  phone     String?
  birthDate DateTime?
  gender    String?
  bloodType String?

  // Location
  regency       String?
  district      String?
  village       String?
  detailAddress String?
  location      Unsupported("geography(Point, 4326)")?

  // Medical and expertise information
  medicalHistory String?
  expertise      String?
  experience     String?

  // Status fields
  status       String  @default("pending") // pending/approved/rejected/inactive/active
  statusTugas  String  @default("available") // available/on_duty/off_duty
  lastLocation String?

  // Metrics
  rating        Float?
  totalMissions Int    @default(0)
  totalHours    Float  @default(0)

  // Relations
  deployments      VolunteerDeployment[]  @relation("VolunteerDeployments")
  schedules        VolunteerSchedule[]    @relation("VolunteerSchedules")
  performance      VolunteerPerformance[] @relation("VolunteerPerformance")
  devices          VolunteerDevice[]      @relation("VolunteerDevices")
  AssetTransaction AssetTransaction[]
  Mission          Mission[]
  CheckIn          CheckIn[]
  Certification    Certification[]

  @@index([userId])
  @@index([status])
  @@index([regency])
  @@index([location])
  @@index([statusTugas])
}

// User sessions for refresh token tracking
model UserSession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  refreshToken String    @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// Incident model with enum status, severity, type, and source fields
model Incident {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Human-readable identifier
  incidentCode String @unique

  // Basic information
  title       String?
  description String?

  // Classification
  disasterType  DisasterType?
  status        IncidentStatus    @default(REPORTED)
  severity      IncidentSeverity?
  priorityScore Float?
  priorityLevel String?

  // Location (PostGIS)
  location       Unsupported("geography(Point, 4326)")?
  region         String?
  kecamatan      String?
  desa           String?
  alamatSpesifik String?

  // Timing
  eventDate DateTime?

  // Impact assessments (JSONB fields)
  dampakManusia    Json?
  dampakRumah      Json?
  dampakFasum      Json?
  dampakVital      Json?
  dampakLingkungan Json?
  needsNumeric     Json?

  // Additional fields
  kondisiMutakhir  String?
  hasShelter       Boolean @default(false)
  isAiGenerated    Boolean @default(false)
  reporterName     String?
  whatsappNumber   String?
  photoData        String? // Base64 encoded or reference to storage
  probabilityScore Float?
  aiFeatures       Json?

  // Relations
  creator   User?   @relation("CreatedIncidents", fields: [userId], references: [id])
  createdBy String?

  actions              IncidentAction[]       @relation("IncidentActions")
  instructions         IncidentInstruction[]  @relation("IncidentInstructions")
  logs                 IncidentLog[]          @relation("IncidentLogs")
  logisticsRequests    LogisticsRequest[]     @relation("LogisticsRequests")
  deployments          VolunteerDeployment[]  @relation("VolunteerDeployments")
  assessments          BuildingAssessment[]   @relation("BuildingAssessments")
  volunteerPerformance VolunteerPerformance[] @relation("VolunteerPerformance")
  userId               String?
  Shelter              Shelter[]
  AssetTransaction     AssetTransaction[]
  Notification         Notification[]
  ChatConversation     ChatConversation[]
  Mission              Mission[]
  IntelReport          IntelReport[]
  NewsItem             NewsItem[]
  Instruction          Instruction[]
  PlaybookExecution    PlaybookExecution[]
  EscalationRule       EscalationRule[]
  EscalationTimer      EscalationTimer[]
  AgentRun             AgentRun[]
  ScoredEvent          ScoredEvent[]
  Prediction           Prediction[]
  VerificationResult   VerificationResult[]
  EvacuationRoute      EvacuationRoute[]

  @@index([status])
  @@index([disasterType])
  @@index([region])
  @@index([location]) // GiST index
  @@index([eventDate])
  @@index([priorityScore, status])
  @@index([kecamatan])
  @@index([isAiGenerated])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([status, createdAt])
}

// Enums for Incident model
enum DisasterType {
  BANJIR
  LONGSOR
  GEMPA
  TSUNAMI
  VOLKANO
  KEBAKARAN_HUTAN
  KEBAKARAN_BANGUNAN
  EKSTREM_CUACA
  WABAH_PENYAKIT
}

enum IncidentStatus {
  REPORTED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  RENDAH
  SEDANG
  TINGGI
  KRITIS
}

// Incident related models
model IncidentAction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String
  incident   Incident @relation("IncidentActions", fields: [incidentId], references: [id])

  kluster         String?
  namaKegiatan    String?
  jumlahPaket     Int?
  penerimaManfaat String?
  targetsMet      Json?

  @@index([incidentId])
  @@index([kluster])
}

model IncidentInstruction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String
  incident   Incident @relation("IncidentInstructions", fields: [incidentId], references: [id])

  nomorSP         String    @unique
  pjNama          String?
  picLapangan     String?
  timAnggota      String?
  armadaDetail    String?
  peralatanDetail String?
  duration        Int? // in minutes
  statusSP        StatusSP? // draft/issued/executing/completed/cancelled

  @@index([incidentId])
  @@index([nomorSP])
  @@index([statusSP])
}

enum StatusSP {
  DRAFT
  ISSUED
  EXECUTING
  COMPLETED
  CANCELLED
}

model IncidentLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  incidentId String
  incident   Incident @relation("IncidentLogs", fields: [incidentId], references: [id])

  fromStatus IncidentStatus?
  toStatus   IncidentStatus?
  changedBy  String? // VARCHAR - could be user ID or name
  note       String?

  @@index([incidentId])
  @@index([createdAt])
}

// Shelter, Warehouse, Asset, AssetTransaction inventory models
model Shelter {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name     String?
  region   String?
  address  String?
  location Unsupported("geography(Point, 4326)")?

  capacity         Int?
  refugeeCount     Int    @default(0)
  waterStockLiters Float?
  toiletCount      Int?

  status      ShelterStatus? // AKTIF/FULL/CLOSED
  score       Float?
  stockStatus String?

  // Optional relation to incident
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  @@index([incidentId])
  @@index([region])
  @@index([status])
}

enum ShelterStatus {
  AKTIF
  FULL
  CLOSED
}

model Warehouse {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String?
  region      String?
  address     String?
  location    Unsupported("geography(Point, 4326)")?
  phoneNumber String?

  type             WarehouseType? // GUDANG/POSKO/DISTRIBUSI
  Asset            Asset[]
  AssetTransaction AssetTransaction[]
  Fulfillment      Fulfillment[]

  @@index([region])
  @@index([type])
}

enum WarehouseType {
  GUDANG
  POSKO
  DISTRIBUSI
}

enum ShelterType {
  EVAKUASI
  SEMENTARA
  PERMANEN
  BERGERAK
}

model Asset {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name     String?
  category AssetCategory? // FOOD/MEDICINE/CLOTHING/SHELTER/TOOLS/OTHER
  quantity Float          @default(0) // >=0 constraint
  unit     String?

  location    Unsupported("geography(Point, 4326)")?
  region      String?
  warehouseId String?
  warehouse   Warehouse?                             @relation(fields: [warehouseId], references: [id])

  qrCode   String  @unique
  status   String?
  minStock Float?

  // Relations
  transactions AssetTransaction[] @relation("AssetTransactions")

  @@index([category])
  @@index([status])
  @@index([qrCode])
  @@index([warehouseId])
  @@index([location])
  @@index([region])
  @@index([region, category])
  @@index([status, quantity])
}

enum AssetCategory {
  FOOD
  MEDICINE
  CLOTHING
  SHELTER
  TOOLS
  OTHER
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
  EXPIRED
}

model AssetTransaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetId String
  asset   Asset  @relation("AssetTransactions", fields: [assetId], references: [id])

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  volunteerId String?
  volunteer   Volunteer? @relation(fields: [volunteerId], references: [id])

  quantity Float                   @default(0) // >0 for most transactions
  type     AssetTransactionType? // checkin/checkout/dispatch/transfer/return/maintenance/retire
  status   AssetTransactionStatus? // pending/approved/completed/rejected/cancelled

  notes String?

  // For transfers between warehouses
  toWarehouseId String?
  toWarehouse   Warehouse? @relation(fields: [toWarehouseId], references: [id])
  toRegion      String?

  @@index([assetId])
  @@index([incidentId])
  @@index([volunteerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([incidentId, createdAt])
}

enum AssetTransactionType {
  CHECKIN
  CHECKOUT
  DISPATCH
  TRANSFER
  RETURN
  MAINTENANCE
  RETIRE
}

enum AssetTransactionStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
}

// Additional models from the full inventory that are needed for completeness
// These will be expanded in subsequent tasks

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actorId String?
  actor   User?   @relation("ActorAuditLogs", fields: [actorId], references: [id])

  action     String? // CREATE/UPDATE/DELETE/VERIFY/etc.
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  payload    Json?
  ipAddress  String?

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  title        String?
  body         String?
  targetRole   String?
  targetRegion String?
  incidentId   String?
  incident     Incident? @relation(fields: [incidentId], references: [id])

  type   String?
  status NotificationStatus? // pending/sent/failed/read
  sentAt DateTime?

  userId String? // FK for direct notifications
  user   User?   @relation("RecipientNotifications", fields: [userId], references: [id])

  isRead Boolean   @default(false)
  readAt DateTime?

  data Json?

  @@index([incidentId])
  @@index([targetRole])
  @@index([status])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model ChatConversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  type            ChatType? // incident/broadcast
  title           String?
  lastMessageAt   DateTime?
  ChatParticipant ChatParticipant[]
  ChatMessage     ChatMessage[]

  @@index([incidentId])
}

enum ChatType {
  INCIDENT
  BROADCAST
}

model ChatParticipant {
  id         String    @id @default(uuid())
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])

  senderId String
  sender   User   @relation("SenderChatMessages", fields: [senderId], references: [id])

  message     String?
  messageType MessageType? // TEXT/IMAGE/FILE/SYSTEM
  fileUrl     String?
  readBy      String[] // Array of user IDs who have read the message

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

model TeamMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  region     String?
  senderId   String?
  sender     User?   @relation(fields: [senderId], references: [id])
  senderName String?
  message    String?

  @@index([region])
  @@index([createdAt])
}

// Intelligence and news models
model IntelNews {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  source       String?
  title        String?
  content      String?
  url          String        @unique
  category     String?
  region       String?
  severity     NewsSeverity? // LOW/MEDIUM/HIGH/CRITICAL
  aiConfidence Float? // 0-1

  @@index([source])
  @@index([category])
  @@index([region])
  @@index([createdAt])
}

enum NewsSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model HistoricalDisaster {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  region       String?
  disasterType DisasterType?
  eventDate    DateTime?
  location     Unsupported("geography(Point, 4326)")?
  time         String?
  source       String?

  @@index([region])
  @@index([disasterType])
  @@index([eventDate])
  @@index([region, eventDate])
}

model Report {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportCode String @unique

  reporterName  String?
  reporterPhone String?
  disasterType  DisasterType?
  description   String?
  location      Unsupported("geography(Point, 4326)")?
  province      String?
  city          String?
  district      String?
  village       String?

  status ReportStatus? // pending/verified/rejected

  @@index([status])
  @@index([createdAt])
}

enum ReportStatus {
  PENDING
  VERIFIED
  REJECTED
}

model DisasterLearning {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  region                 String?
  disasterType           DisasterType?
  occurrenceCount        Int           @default(0)
  totalIncidentsInRegion Int           @default(0)
  avgSeverityScore       Float?
  lastIncidentDate       DateTime?

  @@unique([region, disasterType])
  @@index([region])
  @@index([disasterType])
}

// Mission model for volunteer operations
enum MissionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Mission {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String?
  description String?

  // Optional relation to incident
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  // Mission leader
  leaderId String?
  leader   Volunteer? @relation(fields: [leaderId], references: [id])

  status   MissionStatus?                         @default(PLANNED)
  region   String?
  location Unsupported("geography(Point, 4326)")?

  // Timing
  startDate DateTime?
  endDate   DateTime?

  // Child deployments
  deployments VolunteerDeployment[] @relation("MissionDeployments")

  @@index([incidentId])
  @@index([leaderId])
  @@index([status])
  @@index([region])
}

model LogisticsRequest {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String
  incident   Incident @relation("LogisticsRequests", fields: [incidentId], references: [id])

  requesterRegion   String?
  itemName          String?
  quantityRequested Float                   @default(0) // >0
  status            LogisticsRequestStatus? // pending/approved/fulfilled/rejected/cancelled
  adminNote         String?
  approvedBy        String?
  LogisticsItem     LogisticsItem[]

  @@index([incidentId])
  @@index([status])
  @@index([requesterRegion])
}

enum LogisticsRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
  CANCELLED
}

// LogisticsItem model for detailed line items on a logistics request
model LogisticsItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId String
  request   LogisticsRequest @relation(fields: [requestId], references: [id])

  itemName          String?
  category          String?
  quantityRequested Float   @default(0)
  quantityFulfilled Float   @default(0)
  unit              String?
  notes             String?

  // Child fulfillments
  fulfillments Fulfillment[] @relation("ItemFulfillments")

  @@index([requestId])
  @@index([category])
}

// Fulfillment model for tracking fulfillment of logistics items
model Fulfillment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemId String
  item   LogisticsItem @relation("ItemFulfillments", fields: [itemId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  quantity    Float     @default(0)
  notes       String?
  fulfilledBy String?
  fulfilledAt DateTime?

  @@index([itemId])
  @@index([warehouseId])
}

model VolunteerDeployment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerId String
  volunteer   Volunteer @relation("VolunteerDeployments", fields: [volunteerId], references: [id])

  incidentId String
  incident   Incident @relation("VolunteerDeployments", fields: [incidentId], references: [id])

  missionId String?
  mission   Mission? @relation("MissionDeployments", fields: [missionId], references: [id])

  status          DeploymentStatus?
  checkInLocation Unsupported("geography(Point, 4326)")?
  checkInAt       DateTime?
  checkOutAt      DateTime?
  note            String?

  // Relations
  checkIns CheckIn[] @relation("DeploymentCheckIns")

  @@index([volunteerId])
  @@index([incidentId])
  @@index([missionId])
  @@index([status])
  @@index([volunteerId, status])
}

enum DeploymentStatus {
  APPLIED
  APPROVED
  REJECTED
  DEPLOYED
  COMPLETED
  CANCELLED
}

// CheckIn model for detailed check-in tracking per deployment
enum CheckInStatus {
  CHECKED_IN
  CHECKED_OUT
  MISSING
  CANCELLED
}

model CheckIn {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deploymentId String
  deployment   VolunteerDeployment @relation("DeploymentCheckIns", fields: [deploymentId], references: [id])

  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  location   Unsupported("geography(Point, 4326)")?
  checkInAt  DateTime?
  checkOutAt DateTime?
  status     CheckInStatus?
  notes      String?

  @@index([deploymentId])
  @@index([volunteerId])
  @@index([status])
}

model VolunteerSchedule {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerId String
  volunteer   Volunteer @relation("VolunteerSchedules", fields: [volunteerId], references: [id])

  date       DateTime?
  shiftStart String? // TIME
  shiftEnd   String? // TIME
  status     String?

  @@index([volunteerId])
  @@index([date])
  @@index([volunteerId, date])
}

model VolunteerPerformance {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerId String
  volunteer   Volunteer @relation("VolunteerPerformance", fields: [volunteerId], references: [id])

  incidentId String?
  incident   Incident? @relation("VolunteerPerformance", fields: [incidentId], references: [id])

  hoursWorked       Float?
  missionsCompleted Int     @default(0)
  rating            Int? // 0-5
  notes             String?

  @@index([volunteerId])
  @@index([incidentId])
}

model VolunteerDevice {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerId String
  volunteer   Volunteer @relation("VolunteerDevices", fields: [volunteerId], references: [id])

  token      String    @unique
  platform   String? // e.g., "android", "ios"
  lastActive DateTime?

  @@index([volunteerId])
}

// Building assessment model
model BuildingAssessment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  namaGedung String?
  fungsi     String? // 10+ types
  fungsiLain String?
  alamat     String?
  location   Unsupported("geography(Point, 4326)")?
  region     String?

  imb       String?
  slf       String?
  odnk      String?
  ancaman   Json?
  fasilitas Json?
  peralatan Json?

  ibuHamil      Int     @default(0)
  sakitKronis   Int     @default(0)
  lansia        Int     @default(0)
  balita        Int     @default(0)
