// ===== Playbook and Automation Models (T04) =====

// Playbook: predefined response plans triggered manually or automatically
model Playbook {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name         String
  description  String?
  disasterType DisasterType?
  version      Int           @default(1)
  region       String?

  status PlaybookStatus @default(DRAFT)

  // Relations
  steps      PlaybookStep[]      @relation("PlaybookSteps")
  executions PlaybookExecution[] @relation("PlaybookExecutions")

  @@index([status])
  @@index([disasterType])
  @@index([region])
  @@index([status, disasterType])
}

enum PlaybookStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

// PlaybookStep: individual step within a playbook
model PlaybookStep {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playbookId String
  playbook   Playbook @relation("PlaybookSteps", fields: [playbookId], references: [id])

  stepOrder      Int
  stepType       String // SEND_NOTIFICATION / DEPLOY_VOLUNTEERS / ASSIGN_TASK / ESCALATE / etc.
  stepConfig     Json? // Configuration specific to step type
  timeoutMinutes Int?
  dependsOn      Int? // stepOrder this step depends on (for sequencing)
  description    String?

  @@index([playbookId])
  @@index([playbookId, stepOrder])
}

// PlaybookExecution: tracks active/completed execution of a playbook for an incident
model PlaybookExecution {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playbookId String
  playbook   Playbook @relation("PlaybookExecutions", fields: [playbookId], references: [id])

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  startedBy   String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  status           PlaybookExecutionStatus @default(PENDING)
  currentStepOrder Int                     @default(0)
  result           Json?
  error            String?

  @@index([playbookId])
  @@index([incidentId])
  @@index([status])
  @@index([incidentId, status])
  @@index([startedAt])
}

enum PlaybookExecutionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// ===== Escalation Models =====

// EscalationRule: defines conditions and targets for auto-escalation
model EscalationRule {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String
  description String?

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  triggerCondition Json? // Conditions that trigger escalation
  escalationLevel  Int   @default(1)
  timeoutMinutes   Int? // Max time before escalation fires

  notifyRoles    String[] // Roles to notify on escalation
  notifyUsers    String[] // Specific users to notify
  autoAssignTo   String? // Auto-assign incident to this user/role
  autoAssignRole String?

  isActive Boolean @default(true)
  priority Int     @default(0)

  // Relations
  timers EscalationTimer[] @relation("EscalationTimers")

  @@index([incidentId])
  @@index([isActive])
  @@index([escalationLevel])
  @@index([isActive, priority])
}

// EscalationTimer: tracks active escalation timers per incident
model EscalationTimer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ruleId String
  rule   EscalationRule @relation("EscalationTimers", fields: [ruleId], references: [id])

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  triggeredAt    DateTime  @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?
  timeoutAt      DateTime
  resolvedAt     DateTime?

  status EscalationTimerStatus @default(ACTIVE)
  notes  String?

  @@index([ruleId])
  @@index([incidentId])
  @@index([status])
  @@index([timeoutAt])
  @@index([incidentId, status])
}

enum EscalationTimerStatus {
  ACTIVE
  ACKNOWLEDGED
  TIMEOUT
  RESOLVED
  CANCELLED
}

// ===== Rule Engine Models =====

// RuleDefinition: generic rule engine with JSON Logic conditions and actions
model RuleDefinition {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String
  description String?

  triggerEvent String? // Event name that triggers evaluation (e.g., "incident.created", "report.verified")
  ruleGroup    String? // Category/group for organization
  priority     Int     @default(0)

  conditions Json? // JSON Logic condition tree
  actions    Json? // Actions to execute when conditions match

  isActive        Boolean   @default(true)
  cooldownMinutes Int? // Min interval between re-triggers
  lastTriggeredAt DateTime?

  metadata Json? // Additional metadata (tags, owner, etc.)

  @@index([triggerEvent])
  @@index([ruleGroup])
  @@index([isActive])
  @@index([isActive, priority])
  @@index([triggerEvent, isActive])
}

// ===== AI and Agent Models (T05) =====

// AgentRun: tracks execution of an AI agent session
model AgentRun {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  agentType    String // classifier/predictor/recommender/analyzer
  agentName    String?
  modelVersion String?
  runLabel     String? // Human-readable label for the run

  inputData  Json?
  outputData Json?
  status     AgentRunStatus @default(PENDING)
  durationMs Int?

  triggeredBy String? // userId or "system"
  incidentId  String?
  incident    Incident? @relation(fields: [incidentId], references: [id])

  errorMessage String?
  metadata     Json?

  // Relations
  decisions AgentDecision[] @relation("AgentDecisions")
  auditLogs AgentAuditLog[] @relation("AgentAuditLogs")

  @@index([agentType])
  @@index([status])
  @@index([incidentId])
  @@index([createdAt])
  @@index([agentType, status])
  @@index([triggeredBy])
}

enum AgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// AgentDecision: individual decisions made during an agent run
model AgentDecision {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  agentRunId String
  agentRun   AgentRun @relation("AgentDecisions", fields: [agentRunId], references: [id])

  decisionType  String // classification/prediction/recommendation/action
  decisionLabel String?

  confidence     Float? // 0-1
  reasoning      String?
  inputSnapshot  Json? // Snapshot of input at decision point
  outputSnapshot Json? // Snapshot of output produced

  features          Json? // Feature values used for this decision
  featureImportance Json? // Feature importance/weights

  isAccepted Boolean?
  acceptedBy String? // userId who accepted/reviewed
  acceptedAt DateTime?

  @@index([agentRunId])
  @@index([decisionType])
  @@index([confidence])
  @@index([createdAt])
  @@index([agentRunId, decisionType])
}

// AgentAuditLog: audit trail for autonomous agent actions
model AgentAuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  agentRunId String
  agentRun   AgentRun @relation("AgentAuditLogs", fields: [agentRunId], references: [id])

  action     String // create/update/delete/escalate/notify/approve/reject
  entityType String // incident/volunteer/mission/notification/etc.
  entityId   String?

  oldValue    Json?
  newValue    Json?
  description String?

  performedBy String? // agent name or userId if reviewed
  ipAddress   String?

  @@index([agentRunId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([performedBy])
}

// ===== ML Model Output Models (T05) =====

// ScoredEvent: events scored by ML models for risk/priority assessment
model ScoredEvent {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  eventType   String // incident_report/social_media/news/sensor/field_report
  eventSource String? // Original source identifier
  sourceId    String? // ID of source record (e.g., incidentId, intelReportId)

  features     Json?
  score        Float // 0-1 risk/priority score
  scoreLabel   String? // LOW/MEDIUM/HIGH/CRITICAL
  modelVersion String?
  modelName    String?

  threshold    Float? // Threshold used for classification
  isActionable Boolean?  @default(false)
  expiresAt    DateTime?

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  @@index([eventType])
  @@index([score])
  @@index([modelVersion])
  @@index([incidentId])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([eventType, score])
  @@index([isActionable])
  @@index([eventSource])
}

// Prediction: specific predictions made by ML models with outcome tracking
model Prediction {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  predictionType String // severity/impact/duration/affected_area/casualty
  predictedValue Float?
  predictedLabel String?
  actualValue    Float? // Filled when outcome is known
  actualLabel    String?

  confidence      Float // 0-1
  confidenceLower Float?
  confidenceUpper Float?

  features      Json?
  featureValues Json?
  modelVersion  String?
  modelName     String?

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  targetDate     DateTime? // Date prediction applies to
  predictionDate DateTime  @default(now())
  outcomeDate    DateTime? // When actual outcome was observed

  accuracy   Float? // Calculated after outcome: 1 - |actual - predicted|
  feedback   String? // User feedback on prediction quality
  feedbackBy String?

  @@index([predictionType])
  @@index([confidence])
  @@index([modelVersion])
  @@index([incidentId])
  @@index([targetDate])
  @@index([predictionDate])
  @@index([predictionType, incidentId])
  @@index([outcomeDate])
}

// Forecast: time-series forecasts for operational metrics
model Forecast {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  forecastType String // incident_volume/resource_demand/volunteer_needed/weather_impact
  forecastName String?
  modelVersion String?
  modelName    String?

  horizon    String? // SHORT_TERM/MEDIUM_TERM/LONG_TERM
  confidence Float? // Overall forecast confidence 0-1

  region       String?
  incidentType DisasterType?

  // Forecast data
  dataPoints Json? // Array of {date, predicted, lower, upper} objects
  metadata   Json? // Additional forecast metadata

  startDate   DateTime?
  endDate     DateTime?
  generatedAt DateTime  @default(now())

  // Accuracy tracking
  accuracyScore  Float?
  lastVerifiedAt DateTime?

  @@index([forecastType])
  @@index([horizon])
  @@index([region])
  @@index([incidentType])
  @@index([startDate, endDate])
  @@index([generatedAt])
  @@index([forecastType, region])
}

// ===== Trust and Verification Models (T05) =====

// TrustScore: aggregated trust scores for entities (users, sources, reports)
model TrustScore {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  entityType String // user/volunteer/source/report/intel_report/news_item
  entityId   String // UUID of the entity

  overallScore    Float // 0-1 aggregate trust score
  componentScores Json? // {reliability: 0.8, accuracy: 0.7, consistency: 0.9, ...}

  confidence Float? // Confidence in the trust score itself 0-1

  totalReports     Int      @default(0) // Number of data points contributing
  lastCalculatedAt DateTime @default(now())

  decayFactor Float? // Rate at which score decays over time
  expiresAt   DateTime?

  calculatedBy String? // Model or algorithm used
  metadata     Json?

  @@index([entityType, entityId])
  @@index([overallScore])
  @@index([entityType, overallScore])
  @@index([lastCalculatedAt])
  @@index([expiresAt])
}

// SourceReliability: reliability metrics for information sources
model SourceReliability {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sourceName String?
  sourceType SourceReliabilityType? // OFFICIAL/MEDIA/SOCIAL/CITIZEN/SENSOR/API
  sourceUrl  String                 @unique

  reliabilityScore Float? // 0-1
  accuracyRate     Float? // Historical accuracy rate
  responseRate     Float? // How often source provides timely info

  totalReports    Int @default(0)
  verifiedReports Int @default(0)
  falseReports    Int @default(0)

  lastActiveAt   DateTime?
  lastVerifiedAt DateTime?
  status         SourceReliabilityStatus @default(UNVERIFIED)

  region   String?
  category String?

  notes    String?
  metadata Json?

  @@index([sourceType])
  @@index([reliabilityScore])
  @@index([status])
  @@index([region])
  @@index([sourceType, status])
  @@index([sourceUrl])
}

enum SourceReliabilityType {
  OFFICIAL
  MEDIA
  SOCIAL
  CITIZEN
  SENSOR
  API
}

enum SourceReliabilityStatus {
  UNVERIFIED
  VERIFIED
  TRUSTED
  FLAGGED
  BLOCKED
}

// VerificationResult: results of information verification processes
model VerificationResult {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  claim      String? // The claim being verified
  entityType String? // incident/report/intel/news/location
  entityId   String? // UUID of the entity

  status     VerificationStatus // UNVERIFIED/VERIFIED/CONFIRMED/DISPUTED/REFUTED
  confidence Float? // 0-1 confidence in verification

  verifiedBy String? // userId or "system" / "ai"
  verifiedAt DateTime?

  method   String? // cross_reference/field_report/satellite/official_statement/ai
  evidence Json? // Array of evidence objects {source, content, url, timestamp}
  notes    String?

  reviewerId  String?
  reviewer    User?     @relation(fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  reviewNotes String?

  relatedIncidentId String?
  relatedIncident   Incident? @relation(fields: [relatedIncidentId], references: [id])

  expiresAt DateTime?
  metadata  Json?

  @@index([status])
  @@index([entityType, entityId])
  @@index([method])
  @@index([verifiedBy])
  @@index([relatedIncidentId])
  @@index([createdAt])
  @@index([status, entityType])
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  CONFIRMED
  DISPUTED
  REFUTED
}

enum RegionType {
  PROVINCE
  DISTRICT
  SUB_DISTRICT
  VILLAGE
}

// ===== Region, Zone, and EvacuationRoute Models (PostGIS) =====

model Region {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name         String?
  code         String?                                  @unique
  regionType   RegionType?
  parentId     String?
  parent       Region?                                  @relation("RegionHierarchy", fields: [parentId], references: [id])
  children     Region[]                                 @relation("RegionHierarchy")
  coverageArea Unsupported("geography(Polygon, 4326)")?
  Zone         Zone[]

  @@index([name])
  @@index([regionType])
  @@index([parentId])
  @@index([coverageArea])
}

model Zone {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name         String?
  code         String?
  regionId     String?
  region       Region?                                  @relation(fields: [regionId], references: [id])
  coverageArea Unsupported("geography(Polygon, 4326)")?

  @@index([name])
  @@index([code])
  @@index([regionId])
  @@index([coverageArea])
}

model EvacuationRoute {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name          String?
  description   String?
  route         Unsupported("geography(LineString, 4326)")?
  originId      String?
  origin        String? // origin point name
  destinationId String?
  destination   String? // destination point name
  distance      Float?
  estimatedTime Int? // in minutes
  status        EvacuationRouteStatus?                      @default(ACTIVE)
  incidentId    String?
  incident      Incident?                                   @relation(fields: [incidentId], references: [id])

  @@index([name])
  @@index([status])
  @@index([incidentId])
  @@index([route])
}

enum EvacuationRouteStatus {
  ACTIVE
  BLOCKED
  CLOSED
  UNDER_MAINTENANCE
}

// Federation and security models (T06)

enum FederationNodeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DEGRADED
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CONFLICT
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

enum PiiAction {
  ACCESSED
  STRIPPED
  EXPOSED
  DELETED
  ANONYMIZED
}

model FederationNode {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name            String
  url             String
  apiKeyHash      String?
  status          FederationNodeStatus @default(ACTIVE)
  region          String?
  capabilities    String[]
  lastHeartbeatAt DateTime?
  metadata        Json?

  syncLogs             SyncLog[]
  webhookSubscriptions WebhookSubscription[]

  @@index([status])
  @@index([region])
  @@index([name])
}

model SyncLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  nodeId String
  node   FederationNode @relation(fields: [nodeId], references: [id])

  direction    SyncDirection
  entityType   String
  entityId     String?
  status       SyncStatus    @default(PENDING)
  payload      Json?
  errorMessage String?
  completedAt  DateTime?
  retryCount   Int           @default(0)

  @@index([nodeId])
  @@index([direction])
  @@index([status])
  @@index([createdAt])
}

model WebhookSubscription {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  nodeId String
  node   FederationNode @relation(fields: [nodeId], references: [id])

  url             String
  events          String[]
  secretHash      String?
  status          WebhookStatus @default(ACTIVE)
  lastTriggeredAt DateTime?
  failureCount    Int           @default(0)

  @@index([nodeId])
  @@index([status])
}

model PiiAudit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  action      PiiAction
  entityType  String
  entityId    String
  fieldName   String?
  piiCategory String?
  reason      String?
  ipAddress   String?
  metadata    Json?

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// PHASE-08A ENUMS AND MODELS — CANONICAL EXPANSION FOR BLOCKED DOMAINS
// Additive only. No modifications to existing models above.
// =============================================================================

// =============================================================================
// WARNING ENUMS
// =============================================================================

enum WarningSeverity {
  ADVISORY
  WATCH
  WARNING
  EMERGENCY
}

enum WarningStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// =============================================================================
// HAZARD ENUMS
// =============================================================================

enum HazardSeverity {
  LOW
  MODERATE
  HIGH
  EXTREME
}

// =============================================================================
// EXCLUSION ZONE ENUMS
// =============================================================================

enum ExclusionZoneType {
  DANGER
  RESTRICTED
  CONTROLLED
}

enum ExclusionZoneLevel {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

// =============================================================================
// DECISION ENUMS
// =============================================================================

enum DecisionImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DecisionUrgency {
  LOW
  MEDIUM
  HIGH
}

enum DecisionStatus {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
}

// =============================================================================
// BRIEFING ENUMS
// =============================================================================

enum BriefingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// =============================================================================
// TACTICAL ENUMS
// =============================================================================

enum TacticalPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// =============================================================================
// WARNING MODEL
// Persistence contract for early warning / peringatan dini lifecycle.
// Scalar FKs (incidentId, regionId, createdBy) reference Incident/Region/User
// without Prisma-level @relation — existing models cannot be modified.
// =============================================================================

model Warning {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title         String
  description   String
  severity      WarningSeverity
  status        WarningStatus     @default(ACTIVE)
  affectedAreas String[]
  issuedAt      DateTime
  expiresAt     DateTime
  source        String?

  incidentId String?
  regionId   String?
  createdBy  String?

  @@index([status])
  @@index([severity])
  @@index([incidentId])
  @@index([regionId])
  @@index([issuedAt])
  @@index([expiresAt])
  @@index([status, expiresAt])
}

// =============================================================================
// HAZARD ZONE MODEL
// Persistence contract for mapped hazard zones with polygon geometry.
// Scalar FKs reference Incident and Region without Prisma-level @relation.
// Child VulnerabilityAssessment and ExclusionZone reference HazardZone via scalar FKs.
// =============================================================================

model HazardZone {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name            String
  hazardType      DisasterType
  severity        HazardSeverity
  polygonGeometry Unsupported("geography(Polygon, 4326)")
  description     String?
  population      Int?
  area            Float?

  regionId   String?
  incidentId String?

  @@index([hazardType])
  @@index([severity])
  @@index([regionId])
  @@index([incidentId])
  @@index([polygonGeometry])
}

// =============================================================================
// VULNERABILITY ASSESSMENT MODEL
// Persistence contract for per-zone vulnerability scoring.
// Scalar FKs reference HazardZone, Region, User without Prisma-level @relation.
// factors is Json because factor names and weights vary per methodology.
// =============================================================================

model VulnerabilityAssessment {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  score           Float
  factors         Json?
  recommendations String?
  assessedAt      DateTime  @default(now())

  hazardZoneId String
  regionId     String?
  assessedBy   String?

  @@index([hazardZoneId])
  @@index([regionId])
  @@index([score])
  @@index([assessedAt])
}

// =============================================================================
// EXCLUSION ZONE MODEL
// Persistence contract for danger/restricted/controlled zones.
// Scalar FKs reference HazardZone, Incident, Region without Prisma-level @relation.
// geometry supports arbitrary polygons; radius supports circular zones.
// =============================================================================

model ExclusionZone {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name            String
  geometry        Unsupported("geography(Polygon, 4326)")
  radius          Float?
  restrictionType ExclusionZoneType
  level           ExclusionZoneLevel
  description     String?
  restrictions    String[]
  effectiveFrom   DateTime
  effectiveTo     DateTime?

  hazardZoneId String?
  incidentId   String?
  regionId     String?

  @@index([restrictionType])
  @@index([level])
  @@index([hazardZoneId])
  @@index([incidentId])
  @@index([regionId])
  @@index([effectiveFrom, effectiveTo])
  @@index([level, restrictionType])
}

// =============================================================================
// TACTICAL DATA MODEL
// Persistence contract for tactical per-incident operational data.
// Scalar FK references Incident (required, 1:1) and optional Region/User.
// metadata uses Json for flexible map overlays and resource visibility data.
// =============================================================================

model TacticalData {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String     @unique
  priority   TacticalPriority @default(MEDIUM)
  perimeter  Unsupported("geography(Polygon, 4326)")?
  description    String?
  metadata       Json?
  deployedUnits  Int     @default(0)
  sheltersOccupied Int  @default(0)
  resourcesDeployed Int @default(0)

  regionId  String?
  createdBy String?

  @@index([incidentId])
  @@index([priority])
  @@index([regionId])
  @@index([createdAt])
}

// =============================================================================
// DECISION MODEL
// Persistence contract for human command decisions with approval workflow.
// Scalar FKs reference User (requestedBy required, decidedBy optional) and
// optional Incident, without Prisma-level @relation.
// alternatives is Json because option structures vary per decision template.
// inputFactors is Json because factor names and weights are domain-specific.
// =============================================================================

model Decision {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title       String
  description String
  category    String
  impact      DecisionImpact
  urgency     DecisionUrgency
  status      DecisionStatus   @default(PENDING)

  reasoning    String?
  alternatives Json?
  inputFactors Json?
  riskLevel    DecisionImpact?

  selectedOption String?
  rationale      String?
  requestedBy    String
  decidedBy      String?
  decidedAt      DateTime?

  incidentId String?

  @@index([status])
  @@index([impact])
  @@index([urgency])
  @@index([incidentId])
  @@index([requestedBy])
  @@index([createdAt])
  @@index([incidentId, status])
  @@index([incidentId, createdAt])
}

// =============================================================================
// EXECUTIVE BRIEFING MODEL
// Persistence contract for generated executive briefings with aggregated metrics.
// Scalar FKs reference Incident and User without Prisma-level @relation.
// summary and metrics use Json because structure varies per data source availability.
// =============================================================================

model ExecutiveBriefing {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title           String
  summary         Json?
  metrics         Json?
  recommendations String[]
  audience        String?
  generatedAt     DateTime      @default(now())
  validUntil      DateTime?
  status          BriefingStatus @default(DRAFT)

  incidentId String?
  preparedBy String?

  @@index([status])
  @@index([incidentId])
  @@index([generatedAt])
  @@index([audience])
  @@index([incidentId, generatedAt])
}
