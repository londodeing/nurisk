{
  "name": "aider-autonomous-agent",
  "version": "1.0.0",
  "description": "Autonomous Aider AI agent with token management and role rotation",
  "main": "aider-controller.js",
  "scripts": {
    "start": "node aider-controller.js",
    "test": "jest",
    "dev": "nodemon aider-controller.js",
    "prisma:generate": "cd ../../apps/backend && npx prisma generate",
    "prisma:migrate": "cd ../../apps/backend && npx prisma migrate dev",
    "prisma:studio": "cd ../../apps/backend && npx prisma studio",
    "schema:validate": "cd ../../apps/backend && npx prisma validate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ws": "^8.13.0",
    "fs-extra": "^11.1.1",
    "path": "^0.12.7",
    "child_process": "^1.0.2"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "aider",
    "autonomous",
    "agent",
    "ai",
    "code-assistant",
    "token-management",
    "prisma",
    "database",
    "migration"
  ],
  "author": "PUSDATIN NU Jawa Tengal",
  "license": "MIT"
}
