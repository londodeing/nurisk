{
  "agent_name": "aider-autonomous",
  "agent_type": "code_assistant",
  "version": "1.0.0",
  "description": "Autonomous code assistant agent with token management and role rotation",
  "capabilities": [
    "code_generation",
    "code_review", 
    "refactoring",
    "documentation",
    "testing",
    "debugging"
  ],
  "token_management": {
    "max_tokens_per_session": 100000,
    "warning_threshold": 80000,
    "rotation_threshold": 95000,
    "backup_agents": [
      "claude-agent",
      "gpt-agent", 
      "gemini-agent"
    ]
  },
  "integration": {
    "database_access": true,
    "api_endpoints": [
      "/api/agents/aider/status",
      "/api/agents/aider/execute",
      "/api/agents/aider/rotate"
    ],
    "notification_channels": ["socket.io", "webhook"],
    "priority_level": "high"
  },
  "operational_parameters": {
    "auto_rotation": true,
    "session_timeout": 3600,
    "max_concurrent_tasks": 5,
    "error_retry_count": 3,
    "backup_on_rotation": true
  }
}
