{
  "appId": "com.nupeduli.jateng",
  "appName": "NU Pedra",
  "webDir": "dist",
  "bundledWebRuntime": true,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#006432"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#006432"
    }
  },
  "android": {
    "buildToolsVersion": "34.0.0",
    "compileSdkVersion": 34,
    "minSdkVersion": 24,
    "targetSdkVersion": 34,
    "allowBackup": true,
    "permissions": [
      "android.permission.ACCESS_COARSE_LOCATION",
      "android.permission.ACCESS_FINE_LOCATION",
      "android.permission.ACCESS_BACKGROUND_LOCATION",
      "android.permission.CAMERA",
      "android.permission.READ_EXTERNAL_STORAGE",
      "android.permission.WRITE_EXTERNAL_STORAGE",
      "android.permission.READ_MEDIA_IMAGES",
      "android.permission.READ_MEDIA_VIDEO",
      "android.permission.POST_NOTIFICATIONS",
      "android.permission.RECEIVE_BOOT_COMPLETED",
      "android.permission.VIBRATE",
      "android.permission.WAKE_LOCK",
      "android.permission.FOREGROUND_SERVICE",
      "android.permission.FOREGROUND_SERVICE_LOCATION",
      "android.permission.INTERNET",
      "android.permission.NETWORK_STATE"
    ]
  },
  "ios": {
    "minVersion": "13.0",
    "infoPlist": {
      "NSLocationWhenInUseUsageDescription": "NU Pedra",
      "NSLocationAlwaysAndWhenInUseUsageDescription": "NU Pedra",
      "NSCameraUsageDescription": "NU Pedra",
      "NSPhotoLibraryUsageDescription": "NU Pedra",
      "NSPhotoLibraryAddUsageDescription": "NU Pedra",
      "UIBackgroundModes": [
        "fetch",
        "remote-notification",
        "location"
      ]
    }
  }
}